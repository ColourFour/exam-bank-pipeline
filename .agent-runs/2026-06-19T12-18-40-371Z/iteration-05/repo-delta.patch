+def _unique_path_entries(entries: list[dict[str, str]]) -> list[dict[str, str]]:
+    seen: set[str] = set()
+    unique: list[dict[str, str]] = []
+    for entry in entries:
+        path_value = entry["path"]
+        if path_value in seen:
+            continue
+        seen.add(path_value)
+        unique.append(entry)
+    return unique
+
