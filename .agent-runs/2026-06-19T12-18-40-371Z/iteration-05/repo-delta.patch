+    if width < min_dimension_px or height < min_dimension_px:
+        return image
+
+    mask = image.convert("L").point(lambda pixel: 255 if pixel < nonwhite_threshold else 0, mode="1")
+    bbox = mask.getbbox()
+    if bbox is None:
+        return image
+
+    bands = _nonwhite_row_bands(mask)
